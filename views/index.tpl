% rebase('layout.tpl')
<section class="intro">
    <h1>Новые поступления сезона</h1>
    <p>Подберите базовые вещи прямо на сайте. В наличии верхняя одежда, трикотаж и аксессуары.</p>
</section>

<section class="products">
    <h2>Товары</h2>
    <div class="product-grid">
        <article class="product-card">
            <span class="product-tag">Новинка</span>
            <h3>Кашемировое пальто</h3>
            <p>Светлый песочный оттенок, свободный крой.</p>
            <strong>27 900 ₽</strong>
        </article>
        <article class="product-card">
            <span class="product-tag">Хит</span>
            <h3>Джинсовая куртка</h3>
            <p>Укороченная модель из плотного денима.</p>
            <strong>11 500 ₽</strong>
        </article>
        <article class="product-card">
            <h3>Кардиган</h3>
            <p>Мягкий хлопковый трикотаж графитового цвета.</p>
            <strong>8 900 ₽</strong>
        </article>
        <article class="product-card">
            <h3>Платье-комбинация</h3>
            <p>Минималистичное чёрное платье на бретелях.</p>
            <strong>9 400 ₽</strong>
        </article>
        <article class="product-card">
            <h3>Сумка-тоут</h3>
            <p>Плотная кожа, контрастные строчки, формат А4.</p>
            <strong>13 200 ₽</strong>
        </article>
        <article class="product-card">
            <h3>Шарф</h3>
            <p>Шерстяной шарф в двух оттенках серого.</p>
            <strong>4 300 ₽</strong>
        </article>
    </div>
</section>
